# Copy this to .env and fill in your values

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sdirs_malawi
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# CEIR Integration (MACRA's IMEI registry)
CEIR_API_URL=https://www.ceir.mw/api
CEIR_API_KEY=your_ceir_api_key_here

# MACRA Webhook (SDIRS notifies MACRA when report is verified/resolved)
MACRA_WEBHOOK_URL=https://api.macra.mw/sdirs
MACRA_API_KEY=your_macra_api_key_here

# Pi Node Auth
PI_NODE_SECRET=your_pi_node_secret_here
